# Flask
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<64-random-hex-chars>
FLASK_ENV=production
DATABASE_URL=sqlite:////data/db/ha_analyzer.sqlite

# InfluxDB — use the same token as DOCKER_INFLUXDB_INIT_ADMIN_TOKEN in ha-monitoring/.env
INFLUXDB_URL=http://ha-influxdb:8086
INFLUXDB_TOKEN=<same-token-as-ha-monitoring>
INFLUXDB_ORG=homelab
INFLUXDB_BUCKET=homeassistant

# Ollama (AI LXC)
OLLAMA_URL=http://192.168.0.106:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT=180

# Telegram — create a new bot via @BotFather; get chat_id from /getUpdates
TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>
TELEGRAM_CHAT_ID=<your-chat-id>

# Email (Hover SMTP)
MAIL_SMTP_HOST=mail.hover.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=philip@davidson.net
MAIL_PASSWORD=<hover-smtp-password>
MAIL_FROM=philip@davidson.net
MAIL_TO=philip@davidson.net
